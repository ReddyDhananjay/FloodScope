# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file or any service-account key files.

# ===== MongoDB =====
# MongoDB Atlas (free cloud): https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:<password>@cluster0.xxxxx.mongodb.net/floodscope?retryWrites=true&w=majority
# Local: mongodb://localhost:27017/floodscope

# ===== Server =====
PORT=8000
NODE_ENV=development
# Comma-separated list of origins allowed to make credentialed requests
# (only needed if your frontend is served from a different origin than the API).
# ALLOWED_ORIGINS=https://your-frontend.example.com

# ===== Session =====
# REQUIRED in production. Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# ===== Google OAuth (for login) =====
# Get these from: https://console.cloud.google.com/apis/credentials
# See SETUP-OAUTH.md for step-by-step guide
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret

# ===== Google Earth Engine (for flood detection) =====
# Path to a service-account JSON key file. Keep this file OUTSIDE the repo
# (e.g. in a secrets manager or an untracked local path) — never commit it.
EE_SERVICE_ACCOUNT_KEY=/absolute/path/to/ee-key.json
# Or leave blank and run: earthengine authenticate

# ===== AI (optional) =====
NVIDIA_API_KEY=nvapi-your-key-here
